PRIVATE_DASHBOARD_SLUG=replace-with-a-long-random-route-fragment
DASHBOARD_SECRET_TOKEN=replace-with-a-long-random-token
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# SaaS auth + database mode. Legacy private dashboard still works without PostgreSQL.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/private_invest_dashboard?schema=public
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/private_invest_dashboard?schema=public
AUTH_SECRET=replace-with-a-long-random-auth-secret-at-least-32-chars
NEXTAUTH_URL=https://your-domain.com
AUTH_RATE_LIMIT_WINDOW_SECONDS=60
AUTH_RATE_LIMIT_MAX_REQUESTS=10

GOOGLE_SHEETS_SPREADSHEET_ID=https://docs.google.com/spreadsheets/d/your-sheet-id/edit
# Supports a native Google Sheet or a Drive-hosted Excel workbook shared with the service account
# Give the service account Viewer for read-only mode or Editor for dashboard admin write-back
GOOGLE_SERVICE_ACCOUNT_EMAIL=service-account@project.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","client_email":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"}

COINGECKO_API_KEY=
CS2_PROVIDER_ORDER=steam,manual
CS2_PRICE_STALE_HOURS=72
CS2_BUFF_PROXY_URL=
CSFLOAT_API_KEY=
PRICEMPIRE_API_KEY=
DEFAULT_CURRENCY=USD
PORTFOLIO_CACHE_TTL_SECONDS=300
PRICE_CACHE_TTL_SECONDS=120
SAAS_CRYPTO_PRICE_TTL_SECONDS=120
SAAS_CS2_PRICE_TTL_SECONDS=900
SAAS_TELEGRAM_PRICE_TTL_SECONDS=1800
SAAS_CUSTOM_PRICE_TTL_SECONDS=1800
SAAS_MANUAL_PRICE_STALE_HOURS=168
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=25
TELEGRAM_PRICE_STALE_DAYS=14

# Cache driver: memory or redis_rest (Upstash/Redis REST compatible)
CACHE_DRIVER=memory
CACHE_REDIS_REST_URL=
CACHE_REDIS_REST_TOKEN=
CACHE_KEY_PREFIX=private-invest-dashboard
